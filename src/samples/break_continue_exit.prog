
int main() {
    int i;
    int sum;

    sum = 0;
    i = 0;

    while (i < 20) {
        sum = sum + i;
        if (sum >= 100) {
            break;
        }
        i = i + 1;
    }
    for (i = 0; i < 10; i = i + 1) {
        if (i % 2 == 0) {
            continue;
        }
        sum = sum + 1;
    }

    print("done");
    exit(0);
    return 0;
}
